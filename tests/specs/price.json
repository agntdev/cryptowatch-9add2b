[
  {
    "name": "/price shows watchlist prices",
    "steps": [
      {
        "send": { "text": "/price" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Your watchlist is empty — tap ➕ Add Coin to start tracking."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Price menu button shows watchlist prices",
    "steps": [
      {
        "send": { "callback": "price:menu" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Your watchlist is empty — tap ➕ Add Coin to start tracking."
            }
          }
        ]
      }
    ]
  }
]
